amends "package://github.com/jdx/hk/releases/download/v1.51.0/hk@1.51.0#/Config.pkl"
import "package://github.com/jdx/hk/releases/download/v1.51.0/hk@1.51.0#/Builtins.pkl"

local checks = new Mapping<String, Step> {
    ["ruff"] = Builtins.ruff
    ["ruff-format"] = Builtins.ruff_format
    ["test"] {
        glob = List("**/*.py")
        check = "mise run test"
    }
    // GitHub Actions: pinact pins actions to SHAs, actionlint catches workflow
    // mistakes, zizmor audits for supply-chain and injection risks.
    ["pinact"] = Builtins.pinact
    ["actionlint"] = Builtins.actionlint
    ["zizmor"] = Builtins.zizmor
}

hooks {
    ["pre-commit"] {
        fix = true
        stash = "git"
        steps = checks
    }
    ["fix"] {
        fix = true
        steps = checks
    }
    ["check"] {
        steps = checks
    }
}
